# Unity Cloud Build credentials
# Copy this to .env and fill in your values — never commit .env

# Unity Dashboard → top-right avatar → Organizations → your org → Settings → API Key
UCB_API_KEY=your-unity-cloud-build-api-key

# Visible in the Unity Cloud dashboard URL: cloud.unity.com/orgs/{UCB_ORG_ID}/...
UCB_ORG_ID=your-unity-org-id

# Unity Dashboard → your project → Settings → Project ID
UCB_PROJECT_ID=your-unity-project-id

# The build target name for iOS in your Unity Cloud Build config (e.g. "ios" or "default-ios")
UCB_BUILD_TARGET=your-ios-build-target

# GitHub personal access token with permission to dispatch the upload workflow
GITHUB_PAT=your-github-personal-access-token
